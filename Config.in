# MeowOS Root Configuration

mainmenu "MeowOS Configuration"

config MEOW_VERSION
    string "MeowOS Version"
    default "0.1.0-alpha"
    help
      The version string for your MeowOS build.

menu "System Configuration"

    config MEOW_TARGET_ARCH
        string "Target Architecture"
        default "x86_64"
        help
          The architecture your OS is targeting.

    config MEOW_ENABLE_DEBUG
        bool "Enable Debug Symbols"
        default y
        help
          Compile packages with debug symbols (-g).

endmenu

source toolchain/Config.in
